# ------------------------------------------------------------
# Coding Platform backend environment variables
# ------------------------------------------------------------

# Preferred option: full SQLAlchemy database URL
# Example: postgresql+psycopg2://postgres:postgres@localhost:5432/codingplatform
DATABASE_URL=

# Alternative option: individual DB fields (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codingplatform
DB_USER=postgres
DB_PASSWORD=postgres

# Optional AWS Secrets Manager secret ARN containing JSON with:
# {"username": "...", "password": "..."}
# Used when DB_USER and/or DB_PASSWORD are not set.
DB_SECRET_ARN=

# Judge0 CE endpoint (public CE by default for local use)
JUDGE0_BASE_URL=https://ce.judge0.com

# Optional Judge0 auth token header value (X-Auth-Token)
JUDGE0_API_KEY=

# Shared-secret token required by /proxy/judge0/* endpoint
# External callers must send it via X-Proxy-Token (or X-API-Key)
JUDGE0_PROXY_TOKEN=

# Optional comma-separated allowlist for proxied Judge0 path prefixes
# Defaults: submissions,languages,statuses,config_info,system_info
JUDGE0_PROXY_ALLOWED_PREFIXES=

# JWT settings
JWT_SECRET_KEY=change-me
JWT_EXPIRE_HOURS=8

# Scoring/session behavior
SCORE_PASS_THRESHOLD=70
MAX_ATTEMPTS_PER_LEVEL=5
